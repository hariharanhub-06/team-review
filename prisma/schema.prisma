generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum DayStatus {
  COMPLETED
  IN_PROGRESS
  BLOCKED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  REJECTED
}

enum BreakType {
  LUNCH
  SHORT
  OTHER
}

enum TaskEventType {
  SUBMITTED
  APPROVED
  REJECTED
  WITHDRAWN
  REOPENED
}

model User {
  id                 String     @id @default(cuid())
  name               String
  email              String     @unique
  passwordHash       String
  role               Role       @default(MEMBER)
  expectedDailyHours Float      @default(8)
  active             Boolean    @default(true)
  createdAt          DateTime   @default(now())

  dailyLogs          DailyLog[]
  assignedTasks      Task[]     @relation("TaskAssignee")
}

model DailyLog {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime    @db.Date
  loginAt       DateTime?
  logoutAt      DateTime?
  plannedWork   String?
  workCompleted String?
  status        DayStatus?
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workEntries   WorkEntry[]
  breaks        Break[]

  @@unique([userId, date])
  @@index([date])
}

model Break {
  id         String    @id @default(cuid())
  dailyLogId String
  dailyLog   DailyLog  @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  type       BreakType @default(LUNCH)
  startAt    DateTime
  endAt      DateTime?
  createdAt  DateTime  @default(now())

  @@index([dailyLogId])
}

model Project {
  id           String      @id @default(cuid())
  name         String
  description  String?
  startDate    DateTime?   @db.Date
  endDate      DateTime?   @db.Date
  deliverables String?
  onHold       Boolean     @default(false)
  holdSince    DateTime?
  heldDays     Int         @default(0)
  createdAt    DateTime    @default(now())

  workEntries  WorkEntry[]
  tasks        Task[]
}

model Task {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  startDate   DateTime?   @db.Date
  endDate     DateTime?   @db.Date
  /// How critical the task is, 1 (trivial) to 10 (mission-critical).
  /// Weights the task's contribution to the assignee's impact score.
  criticality Int         @default(5)
  status       TaskStatus @default(TODO)
  completedAt  DateTime?
  submittedAt  DateTime?
  reviewNote   String?
  assigneeId  String?
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  workEntries WorkEntry[]
  events      TaskEvent[]

  @@index([projectId])
}

/// Audit trail of a task's review cycle (submit -> approve/reject -> resubmit...).
/// Powers the admin notification feed and the "how many times did this bounce" history.
model TaskEvent {
  id        String        @id @default(cuid())
  taskId    String
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      TaskEventType
  note      String?
  actorId   String?
  actorName String?
  createdAt DateTime      @default(now())

  @@index([taskId])
  @@index([createdAt])
}

model WorkEntry {
  id              String   @id @default(cuid())
  dailyLogId      String
  dailyLog        DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskDescription String
  hoursWorked     Float
  createdAt       DateTime @default(now())

  @@index([dailyLogId])
  @@index([projectId])
  @@index([taskId])
}
